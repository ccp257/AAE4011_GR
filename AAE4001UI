    def _init_config(self):
        """Shared tk.StringVar config — passed to all tabs."""
        self.cfg = {
            "api_key":     tk.StringVar(value="5cH07UbHyNu3Wa3bLsbd"),
            "dataset_dir": tk.StringVar(
                value=r"C:\Python\AAE4011\dataset"),
            "runs_dir":    tk.StringVar(
                value=r"C:\Python\AAE4011\runs"),
            "weights":     tk.StringVar(
                value=r"C:\Python\AAE4011\runs\meteor_detector"
                      r"\weights\best.pt"),
            "video_path":  tk.StringVar(
                value=r"C:\Python\AAE4011\video\V3.mp4"),
            "image_dir":   tk.StringVar(value=""),
            "model_base":  tk.StringVar(value="yolov8m.pt"),
            "epochs":      tk.StringVar(value="50"),
            "img_size":    tk.StringVar(value="640"),
            "batch_size":  tk.StringVar(value="8"),
            "conf_thresh": tk.DoubleVar(value=0.40),
        }

    def _build_layout(self):
        # ── Left sidebar ──────────────────────────────────
        sidebar = ctk.CTkFrame(self, width=200,
                               fg_color=PANEL,
                               corner_radius=0)
        sidebar.pack(side="left", fill="y")
        sidebar.pack_propagate(False)

        ctk.CTkLabel(sidebar,
                     text="🌠\nMETEOR\nDETECTOR",
                     font=("Segoe UI", 15, "bold"),
                     text_color=CYAN,
                     justify="center"
                     ).pack(pady=(28, 20))

        # Sidebar nav buttons
        nav_items = [
            ("⚙️  Setup",    0),
            ("🏋️  Training", 1),
            ("🎬  Inference",2),
            ("📊  Results",  3),
        ]
        self._nav_btns = []
        for label, idx in nav_items:
            b = ctk.CTkButton(
                sidebar, text=label, anchor="w",
                width=170, height=38,
                font=("Segoe UI", 12),
                fg_color="transparent",
                hover_color=ACCENT,
                text_color="#ccccee",
                command=lambda i=idx: self._switch(i))
            b.pack(pady=3, padx=14)
            self._nav_btns.append(b)

        # Version label at bottom
        ctk.CTkLabel(sidebar, text="YOLOv8  •  AAE4011",
                     text_color="#333355",
                     font=("Segoe UI", 9)
                     ).pack(side="bottom", pady=14)

        # ── Right area: tabs + log ────────────────────────
        right = ctk.CTkFrame(self, fg_color=BG,
                             corner_radius=0)
        right.pack(side="left", fill="both", expand=True)
        right.rowconfigure(0, weight=3)
        right.rowconfigure(1, weight=1)
        right.columnconfigure(0, weight=1)

        # Tab container
        self._tab_frames = []
        tab_host = ctk.CTkFrame(right, fg_color=BG)
        tab_host.grid(row=0, column=0,
                      sticky="nsew", padx=10, pady=(10,4))
        tab_host.columnconfigure(0, weight=1)
        tab_host.rowconfigure(0, weight=1)

        # Shared log
        log_frame = ctk.CTkFrame(right, fg_color=PANEL,
                                  corner_radius=10)
        log_frame.grid(row=1, column=0,
                       sticky="nsew", padx=10, pady=(0,10))
        ctk.CTkLabel(log_frame, text="🖥  Console",
                     text_color=CYAN,
                     font=("Segoe UI", 11, "bold")
                     ).pack(anchor="w", padx=12, pady=(6,0))
        self.logbox = LogBox(log_frame, height=130)
        self.logbox.pack(fill="both", expand=True,
                         padx=10, pady=(2,8))
        self.logbox.log("✅ Meteor Detector UI ready.")

        # Instantiate tabs
        results_tab = ResultsTab(tab_host)
        tabs = [
            SetupTab(tab_host, self.cfg),
            TrainTab(tab_host, self.cfg, self.logbox),
            InferTab(tab_host, self.cfg,
                     self.logbox, results_tab),
            results_tab,
        ]
        for t in tabs:
            t.grid(row=0, column=0, sticky="nsew")
            self._tab_frames.append(t)

        self._switch(0)   # show Setup tab first

    def _switch(self, idx: int):
        for i, (btn, tab) in enumerate(
                zip(self._nav_btns, self._tab_frames)):
            if i == idx:
                tab.tkraise()
                btn.configure(fg_color=ACCENT,
                               text_color=CYAN)
            else:
                btn.configure(fg_color="transparent",
                               text_color="#ccccee")


