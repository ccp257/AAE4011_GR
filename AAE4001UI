# ════════════════════════════════════════════════════════════
class InferTab(ctk.CTkFrame):
    def __init__(self, master, config: dict,
                 logbox: LogBox, results_tab):
        super().__init__(master, fg_color="transparent")
        self.cfg        = config
        self.log        = logbox
        self.results    = results_tab
        self._build()

    def _build(self):
        ctk.CTkLabel(self, text="🎬  Run Inference",
                     font=("Segoe UI", 16, "bold"),
                     text_color=CYAN
                     ).pack(anchor="w", padx=20, pady=(16,8))

        # ── Mode toggle ──
        self.mode = ctk.StringVar(value="video")
        mode_frame = ctk.CTkFrame(self, fg_color=ACCENT,
                                  corner_radius=10)
        mode_frame.pack(fill="x", padx=20, pady=6)
        ctk.CTkRadioButton(mode_frame, text="🎥  Video",
                           variable=self.mode, value="video",
                           text_color=CYAN,
                           ).pack(side="left", padx=20, pady=10)
        ctk.CTkRadioButton(mode_frame, text="🖼️  Images",
                           variable=self.mode, value="images",
                           text_color=CYAN,
                           ).pack(side="left", padx=20)

        # ── Conf threshold slider ──
        slider_frame = ctk.CTkFrame(self, fg_color="transparent")
        slider_frame.pack(fill="x", padx=20, pady=8)
        ctk.CTkLabel(slider_frame, text="Confidence:",
                     text_color="#aaaacc").pack(side="left")
        self.conf_lbl = ctk.CTkLabel(slider_frame, text="0.40",
                                     text_color=CYAN, width=40)
        self.conf_lbl.pack(side="right", padx=(0,20))
        sl = ctk.CTkSlider(slider_frame, from_=0.1, to=0.9,
                           number_of_steps=16,
                           variable=self.cfg["conf_thresh"],
                           command=lambda v: self.conf_lbl.configure(
                               text=f"{float(v):.2f}"),
                           button_color=CYAN,
                           progress_color=CYAN)
        sl.pack(side="left", fill="x", expand=True, padx=10)

        # ── Run button ──
        self.run_btn = ctk.CTkButton(
            self, text="▶  Run Detection",
            font=("Segoe UI", 13, "bold"),
            height=40,
            fg_color="#1a5e3a",
            hover_color="#1a7e4a",
            command=self._run)
        self.run_btn.pack(padx=20, pady=14, fill="x")

        # ── Live stats ──
        stats = ctk.CTkFrame(self, fg_color=ACCENT,
                             corner_radius=10)
        stats.pack(fill="x", padx=20, pady=4)
        self.total_lbl = ctk.CTkLabel(stats,
            text="🌠 Unique Meteors: —",
            font=("Segoe UI", 14, "bold"), text_color=CYAN)
        self.total_lbl.pack(side="left", padx=20, pady=10)
        self.max_lbl = ctk.CTkLabel(stats,
            text="📊 Max / Frame: —",
            font=("Segoe UI", 14), text_color="#aaaacc")
        self.max_lbl.pack(side="left", padx=20)

    def _run(self):
        self.run_btn.configure(state="disabled")
        mode = self.mode.get()

        def _go():
            from ultralytics import YOLO
            weights = self.cfg["weights"].get()
            conf    = float(self.cfg["conf_thresh"].get())
            runs    = self.cfg["runs_dir"].get()

            if not os.path.exists(weights):
                self.log.log(f"❌ Weights not found: {weights}")
                self.after(0, lambda: self.run_btn.configure(
                    state="normal"))
                return

            model = YOLO(weights)
            self.log.log(f"🔍 Running inference ({mode})…")

            if mode == "video":
                src = self.cfg["video_path"].get()
                if not os.path.exists(src):
                    self.log.log(f"❌ Video not found: {src}")
                    return
                results = model.track(
                    source=src,
                    tracker="bytetrack.yaml",
                    conf=conf, iou=0.5,
                    save=True,
                    project=runs,
                    name="meteor_count_video",
                    stream=True)

                unique_ids, frame_counts = set(), []
                for r in results:
                    if r.boxes.id is not None:
                        ids = r.boxes.id.int().tolist()
                        unique_ids.update(ids)
                        frame_counts.append(len(ids))
                    else:
                        frame_counts.append(0)

                total = len(unique_ids)
                peak  = max(frame_counts) if frame_counts else 0
                self.log.log(
                    f"\n🌠 Unique meteors : {total}"
                    f"\n📊 Peak per frame : {peak}")
                self.after(0, lambda: self.total_lbl.configure(
                    text=f"🌠 Unique Meteors: {total}"))
                self.after(0, lambda: self.max_lbl.configure(
                    text=f"📊 Max / Frame: {peak}"))
                self.after(0,
                    lambda: self.results.update_plot(frame_counts))

            else:  # images
                src  = self.cfg["image_dir"].get()
                imgs = glob.glob(os.path.join(src, "*.jpg")) + \
                       glob.glob(os.path.join(src, "*.png"))
                if not imgs:
                    self.log.log(f"❌ No images in: {src}")
                    return
                total = 0
                for p in imgs:
                    r = model.predict(source=p, conf=conf,
                                      save=True, project=runs,
                                      name="meteor_count_images")
                    n = len(r[0].boxes)
                    total += n
                    self.log.log(
                        f"  {os.path.basename(p)}: {n} meteor(s)")
                self.log.log(f"\n🌠 Total: {total} meteor(s)")
                self.after(0, lambda: self.total_lbl.configure(
                    text=f"🌠 Total Meteors: {total}"))

            self.after(0, lambda: self.run_btn.configure(
                state="normal"))

        threading.Thread(target=_go, daemon=True).start()


