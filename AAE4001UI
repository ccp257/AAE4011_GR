#  RESULTS TAB — Embedded Matplotlib chart
# ════════════════════════════════════════════════════════════
class ResultsTab(ctk.CTkFrame):
    def __init__(self, master):
        super().__init__(master, fg_color="transparent")
        self._build()

    def _build(self):
        ctk.CTkLabel(self, text="📊  Detection Results",
                     font=("Segoe UI", 16, "bold"),
                     text_color=CYAN
                     ).pack(anchor="w", padx=20, pady=(16,8))

        self.fig, self.ax = plt.subplots(figsize=(9, 3.8),
                                         facecolor=BG)
        self.ax.set_facecolor(BG)
        self.ax.set_title("Run inference to see results",
                          color="#555577", fontsize=12)
        self.canvas = FigureCanvasTkAgg(self.fig, master=self)
        self.canvas.get_tk_widget().pack(
            fill="both", expand=True, padx=20, pady=6)

        self.save_btn = ctk.CTkButton(
            self, text="💾 Save Plot",
            command=self._save,
            fg_color=ACCENT,
            hover_color="#2a2a5e")
        self.save_btn.pack(padx=20, pady=8, anchor="e")

    def update_plot(self, frame_counts: list):
        self.ax.clear()
        self.ax.set_facecolor(BG)
        x = range(len(frame_counts))
        self.ax.plot(frame_counts, color=CYAN, linewidth=1.2)
        self.ax.fill_between(x, frame_counts,
                             alpha=0.25, color=CYAN)
        self.ax.set_title("🌠 Meteors Detected Per Frame",
                          color=CYAN, fontsize=13)
        self.ax.set_xlabel("Frame", color="#888899")
        self.ax.set_ylabel("Count",  color="#888899")
        self.ax.tick_params(colors="#888899")
        for spine in self.ax.spines.values():
            spine.set_edgecolor("#333355")
        self.fig.tight_layout()
        self.canvas.draw()

    def _save(self):
        path = filedialog.asksaveasfilename(
            defaultextension=".png",
            filetypes=[("PNG","*.png")])
        if path:
            self.fig.savefig(path, dpi=150,
                             facecolor=BG)
            messagebox.showinfo("Saved", f"Plot saved:\n{path}")


