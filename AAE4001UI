# ════════════════════════════════════════════════════════════
class TrainTab(ctk.CTkFrame):
    def __init__(self, master, config: dict, logbox: LogBox):
        super().__init__(master, fg_color="transparent")
        self.cfg = config
        self.log = logbox
        self._build()

    def _build(self):
        self.columnconfigure(1, weight=1)

        ctk.CTkLabel(self, text="🚀  Train YOLOv8",
                     font=("Segoe UI", 16, "bold"),
                     text_color=CYAN
                     ).grid(row=0, column=0, columnspan=4,
                            padx=20, pady=(16,10), sticky="w")

        # ── Hyperparameters ──
        params = [
            ("Base Model", "model_base",
             ["yolov8n.pt","yolov8s.pt","yolov8m.pt","yolov8l.pt"]),
            ("Epochs",     "epochs",     None),
            ("Image Size", "img_size",   None),
            ("Batch Size", "batch_size", None),
            ("Conf Thresh","conf_thresh",None),
        ]
        for i, (lbl, key, opts) in enumerate(params):
            ctk.CTkLabel(self, text=lbl, anchor="w",
                         text_color="#aaaacc"
                         ).grid(row=i+1, column=0,
                                padx=(20,8), pady=5, sticky="w")
            if opts:
                w = ctk.CTkOptionMenu(self, values=opts,
                                      variable=self.cfg[key],
                                      fg_color=ACCENT,
                                      button_color="#2a2a5e",
                                      width=160)
            else:
                w = ctk.CTkEntry(self, textvariable=self.cfg[key],
                                 width=160, fg_color=ACCENT)
            w.grid(row=i+1, column=1, pady=5, sticky="w")

        # ── Progress bar ──
        self.progress = ctk.CTkProgressBar(self, width=420,
                                           progress_color=CYAN)
        self.progress.set(0)
        self.progress.grid(row=7, column=0, columnspan=4,
                           padx=20, pady=(14,4), sticky="ew")
        self.status_lbl = ctk.CTkLabel(self, text="Idle",
                                       text_color="#666699")
        self.status_lbl.grid(row=8, column=0, columnspan=4,
                             padx=20, sticky="w")

        # ── Buttons ──
        btn_frame = ctk.CTkFrame(self, fg_color="transparent")
        btn_frame.grid(row=9, column=0, columnspan=4,
                       padx=20, pady=10, sticky="w")
        ctk.CTkButton(btn_frame, text="📦 Download Dataset",
                      command=self._download,
                      fg_color="#1a3a5e",
                      hover_color="#1a4a7e"
                      ).pack(side="left", padx=(0,10))
        self.train_btn = ctk.CTkButton(
                      btn_frame, text="🏋️ Start Training",
                      command=self._train,
                      fg_color="#1a5e3a",
                      hover_color="#1a7e4a")
        self.train_btn.pack(side="left")

    def _download(self):
        def _run():
            from roboflow import Roboflow
            self.log.log("📦 Connecting to Roboflow...")
            try:
                rf = Roboflow(api_key=self.cfg["api_key"].get())
                project = rf.workspace("dp-meteory"
                          ).project("meteors-8m2qc")
                ds = project.version(2).download(
                         "yolov8",
                         location=self.cfg["dataset_dir"].get())
                self.log.log(f"✅ Dataset saved: {ds.location}")
            except Exception as e:
                self.log.log(f"❌ Download failed: {e}")
        threading.Thread(target=_run, daemon=True).start()

    def _train(self):
        self.train_btn.configure(state="disabled")
        self.progress.set(0)
        self.status_lbl.configure(text="Training…")

        def _run():
            from ultralytics import YOLO
            epochs = int(self.cfg["epochs"].get())
            try:
                model = YOLO(self.cfg["model_base"].get())
                data_yaml = os.path.join(
                    self.cfg["dataset_dir"].get(), "data.yaml")
                self.log.log("🚀 Training started…")
                # Redirect stdout to log
                sys.stdout = self.log
                model.train(
                    data=data_yaml,
                    epochs=epochs,
                    imgsz=int(self.cfg["img_size"].get()),
                    batch=int(self.cfg["batch_size"].get()),
                    name="meteor_detector",
                    project=self.cfg["runs_dir"].get(),
                    patience=10, augment=True,
                    degrees=0, fliplr=0.5, mosaic=1.0,
                    verbose=True, device=0
                )
                sys.stdout = sys.__stdout__
                self.log.log("\n✅ Training complete!")
                self.after(0, lambda: self.progress.set(1))
                self.after(0, lambda: self.status_lbl.configure(
                    text="✅ Done"))
            except Exception as e:
                sys.stdout = sys.__stdout__
                self.log.log(f"❌ Training error: {e}")
                self.after(0, lambda: self.status_lbl.configure(
                    text="❌ Error"))
            finally:
                self.after(0, lambda: self.train_btn.configure(
                    state="normal"))

        threading.Thread(target=_run, daemon=True).start()


