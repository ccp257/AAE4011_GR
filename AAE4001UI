# ════════════════════════════════════════════════════════════
class SetupTab(ctk.CTkFrame):
    def __init__(self, master, config: dict):
        super().__init__(master, fg_color="transparent")
        self.cfg = config
        self._build()

    def _row(self, label, var, row, browse=None):
        ctk.CTkLabel(self, text=label, anchor="w",
                     text_color=CYAN).grid(row=row, column=0,
                     padx=(20,8), pady=6, sticky="w")
        entry = ctk.CTkEntry(self, textvariable=var, width=380,
                             fg_color=ACCENT)
        entry.grid(row=row, column=1, pady=6, sticky="ew")
        if browse:
            ctk.CTkButton(self, text="📂", width=36,
                          command=browse,
                          fg_color=ACCENT,
                          hover_color="#2a2a5e"
                          ).grid(row=row, column=2, padx=8)

    def _build(self):
        self.columnconfigure(1, weight=1)
        ctk.CTkLabel(self, text="⚙️  Configuration",
                     font=("Segoe UI", 16, "bold"),
                     text_color=CYAN).grid(
                     row=0, column=0, columnspan=3,
                     padx=20, pady=(16,10), sticky="w")

        self._row("Roboflow API Key",
                  self.cfg["api_key"], 1)
        self._row("Dataset Dir",
                  self.cfg["dataset_dir"], 2,
                  lambda: self.cfg["dataset_dir"].set(
                      filedialog.askdirectory()))
        self._row("Runs Dir",
                  self.cfg["runs_dir"], 3,
                  lambda: self.cfg["runs_dir"].set(
                      filedialog.askdirectory()))
        self._row("Best Weights (.pt)",
                  self.cfg["weights"], 4,
                  lambda: self.cfg["weights"].set(
                      filedialog.askopenfilename(
                          filetypes=[("PT files","*.pt")])))

        # Divider
        ctk.CTkLabel(self, text="─" * 60,
                     text_color="#333355").grid(
                     row=5, column=0, columnspan=3, pady=8)
        ctk.CTkLabel(self, text="🎬  Inference Source",
                     font=("Segoe UI", 14, "bold"),
                     text_color=CYAN).grid(
                     row=6, column=0, columnspan=3,
                     padx=20, sticky="w")

        self._row("Video Path (.mp4)",
                  self.cfg["video_path"], 7,
                  lambda: self.cfg["video_path"].set(
                      filedialog.askopenfilename(
                          filetypes=[("Videos","*.mp4 *.avi *.mov")])))
        self._row("Image Dir",
                  self.cfg["image_dir"], 8,
                  lambda: self.cfg["image_dir"].set(
                      filedialog.askdirectory()))

        ctk.CTkLabel(self, text="✅  Changes apply immediately to all tabs.",
                     text_color="#666699",
                     font=("Segoe UI", 11)
                     ).grid(row=9, column=0, columnspan=3,
