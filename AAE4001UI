# ════════════════════════════════════════════════════════════
#  LOG WIDGET — thread-safe scrollable console
# ════════════════════════════════════════════════════════════
class LogBox(ctk.CTkTextbox):
    def __init__(self, master, **kw):
        super().__init__(master, state="disabled",
                         font=("Consolas", 11),
                         fg_color=PANEL, text_color="#b0e0ff",
                         wrap="word", **kw)
        self._q = queue.Queue()
        self._poll()

    def write(self, msg):          # acts as sys.stdout
        self._q.put(msg)

    def flush(self): pass          # needed for sys.stdout redirect

    def log(self, msg):
        self._q.put(msg + "\n")

    def _poll(self):
        while not self._q.empty():
            msg = self._q.get_nowait()
            self.configure(state="normal")
            self.insert("end", msg)
            self.see("end")
            self.configure(state="disabled")
        self.after(100, self._poll)


